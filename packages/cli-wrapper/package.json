{
  "name": "@localcoast/cli-wrapper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "localcoast bin: mcp-stdio shim, install-mcp, run-wrapper (Tier 2), node-agent.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "localcoast": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node-agent": {
      "types": "./dist/node-agent.d.ts",
      "default": "./dist/node-agent.js"
    },
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@localcoast/core": "workspace:*",
    "@localcoast/mcp": "workspace:*",
    "@localcoast/protocol-types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "zod": "^4.0.0"
  }
}
